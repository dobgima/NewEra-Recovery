generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "windows"]
}

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
  directUrl         = env("DIRECT_DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

enum UserRole {
  USER
  PEER
  ADMIN
  CLINICIAN
}

enum RecoveryModality {
  AA
  NA
  SMART
  DHARMA
  THERAPY
  MEDICATION_ASSISTED
  FAITH_BASED
  OTHER
}

enum MoodLevel {
  VERY_LOW
  LOW
  NEUTRAL
  GOOD
  GREAT
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum PeerRequestStatus {
  PENDING
  ACCEPTED
  DECLINED
  CANCELLED
}

enum ResourceType {
  ARTICLE
  VIDEO
  WORKSHEET
  AUDIO
  GUIDE
}

model User {
  id                String              @id @default(uuid())
  email             String              @unique
  passwordHash      String
  role              UserRole            @default(USER)
  isActive          Boolean             @default(true)
  
  // Password Recovery
  passwordResetToken    String?
  passwordResetExpiresAt DateTime?
  
  // 2FA
  twoFactorEnabled      Boolean           @default(false)
  twoFactorSecret       String?
  twoFactorMethod       String?           @default("email")  // "email" or "sms"
  
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  profile           UserProfile?
  preferences       RecoveryPreference?
  checkIns          CheckIn[]
  recoveryPlan      RecoveryPlan?
  milestones        Milestone[]
  peerRequestsSent  PeerSupportRequest[] @relation("PeerRequestsSent")
  peerRequestsRecv  PeerSupportRequest[] @relation("PeerRequestsReceived")
  crisisPlan        CrisisPlan?
  supportContacts   SupportContact[]
  refreshTokens     RefreshToken[]
  twoFactorSessions TwoFactorSession[]

  @@index([email])
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  revokedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
}

model TwoFactorSession {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  code      String   // The 6-digit OTP code being verified
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
}

model AuditLog {
  id          String   @id @default(uuid())
  eventType   String
  userId      String?
  resourceId  String?
  resourceType String?
  action      String
  details     Json     @default("{}")
  ipAddress   String?
  userAgent   String?
  sessionId   String?
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([eventType])
  @@index([createdAt])
}

model UserProfile {
  id                String      @id @default(uuid())
  userId            String      @unique
  firstName         String
  lastName          String
  displayName       String?
  zipCode           String?
  sobrietyDate      DateTime?
  phone             String?
  avatarUrl         String?
  insuranceProvider String?
  timezone          String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  user              User        @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RecoveryPreference {
  id                String              @id @default(uuid())
  userId            String              @unique
  primaryModality   RecoveryModality?
  secondaryModality RecoveryModality?
  wantsReminders    Boolean             @default(true)
  wantsPeerSupport  Boolean             @default(true)
  dailyCheckinHour  Int?
  timezone          String?
  notificationPrefs Json                @default("{}")
  reminderPrefs     Json                @default("{}")
  theme             String              @default("light")
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  user              User                @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DailyFeedItem {
  id                String      @id @default(uuid())
  title             String
  body              String
  category          String
  dayKey            String?     @unique
  isActive          Boolean     @default(true)
  createdAt         DateTime    @default(now())
}

model CheckIn {
  id            String    @id @default(uuid())
  userId        String
  mood          MoodLevel
  cravingsLevel Int
  triggers      String[]
  notes         String?
  feltUnsafe    Boolean   @default(false)
  needsSupport  Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user       User       @relation(fields: [userId], references: [id])
  riskScore   RiskScore?

  @@index([userId, createdAt])
}

model RiskScore {
  id                 String    @id @default(uuid())
  checkInId          String    @unique
  score              Int
  level              RiskLevel
  explanation        String
  factors            String[]
  recommendedAction  String
  encouragement      String
  crisisEscalation   Boolean
  createdAt          DateTime  @default(now())

  checkIn CheckIn @relation(fields: [checkInId], references: [id], onDelete: Cascade)
}

model RecoveryPlan {
  id                String      @id @default(uuid())
  userId            String      @unique
  goals             String[]
  copingTools       String[]
  commitments       String[]
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  user              User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model SupportContact {
  id                String      @id @default(uuid())
  userId            String
  name              String
  relationship      String?
  phone             String?
  email             String?
  isEmergency       Boolean     @default(false)
  isPrimary         Boolean     @default(false)
  deletedAt         DateTime?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  user              User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PeerSupportRequest {
  id                String              @id @default(uuid())
  requesterId       String
  recipientId       String
  message           String?
  status            PeerRequestStatus   @default(PENDING)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  requester         User                @relation("PeerRequestsSent", fields: [requesterId], references: [id], onDelete: Cascade)
  recipient         User                @relation("PeerRequestsReceived", fields: [recipientId], references: [id], onDelete: Cascade)

  @@index([requesterId])
  @@index([recipientId])
  @@index([status])
}

model Milestone {
  id                String      @id @default(uuid())
  userId            String
  title             String
  description       String?
  achievedAt        DateTime
  badgeCode         String?
  createdAt         DateTime    @default(now())

  user              User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([achievedAt])
}

model Resource {
  id                String        @id @default(uuid())
  title             String
  description       String?
  url               String?
  type              ResourceType
  tags              String[]
  isFeatured        Boolean       @default(false)
  createdAt         DateTime      @default(now())
}

model CrisisPlan {
  id                String      @id @default(uuid())
  userId            String      @unique
  warningSigns      String[]
  copingSteps       String[]
  emergencyInstructions String[]
  crisisLine        String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  user              User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model TreatmentProvider {
  id                String      @id @default(uuid())
  name              String
  zipCode           String
  city              String
  state             String
  latitude          Float?
  longitude         Float?
  insuranceAccepted String[]
  modalities        String[]
  hasCrisisSupport  Boolean     @default(false)
  phone             String?
  website           String?
  createdAt         DateTime    @default(now())

  @@index([zipCode])
  @@index([latitude, longitude])
}