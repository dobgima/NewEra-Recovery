# New Era Recovery - Backend Environment Variables
# Copy this file to .env and fill in the values for your environment

# ============================================
# Application
# ============================================

# Node environment: development, test, or production
NODE_ENV=development

# Server port (default: 4000)
PORT=4000

# ============================================
# Database
# ============================================

# Main database connection string (REQUIRED)
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/recovery_health_aid

# Direct database URL for migrations (optional, defaults to DATABASE_URL)
# Use for read replicas or special connection handling
DIRECT_DATABASE_URL=

# Shadow database URL for Prisma migrations (optional)
# Prisma uses this to verify migrations in an isolated database
SHADOW_DATABASE_URL=

# ============================================
# Authentication & JWT
# ============================================

# JWT secret for access tokens (REQUIRED - use a strong random string)
# Generate with: openssl rand -hex 32
JWT_ACCESS_SECRET=your-super-secret-access-token-key-change-me

# JWT secret for refresh tokens (REQUIRED - use a different strong random string)
# Generate with: openssl rand -hex 32
JWT_REFRESH_SECRET=your-super-secret-refresh-token-key-change-me

# JWT expiration times
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ============================================
# CORS & Security
# ============================================

# Allowed origins for CORS (comma-separated)
# Include both frontend URLs for your environments
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173,https://app.newerarecovery.app

# ============================================
# Redis Cache (Optional)
# ============================================

# Enable or disable Redis caching (true/false)
# Set to 'false' for local development without Redis
# Default: true
REDIS_ENABLED=true

# Redis connection URL
# Format: redis://[:password]@host:port[/database]
# Default: redis://localhost:6379
# Leave as default for local development with Redis
REDIS_URL=redis://localhost:6379

# Cache TTL in seconds (default: 3600 = 1 hour)
REDIS_CACHE_TTL=3600

# ============================================
# Development Notes
# ============================================

# For local development WITHOUT Redis:
# - Set REDIS_ENABLED=false
# - Comment out or remove REDIS_URL
# - App will work normally, just without caching
# - Ensure PostgreSQL is running
# - Run migrations: npx prisma migrate dev
#
# For local development WITH Redis:
# - Set REDIS_ENABLED=true
# - Ensure Redis is running (brew install redis)
# - Start Redis: brew services start redis
# - Run migrations: npx prisma migrate dev
#
# For production deployment:
# - Use strong, unique values for all secrets
# - Never commit .env file to version control
# - Store secrets in your deployment platform's secret manager
# - Use environment-specific URLs for databases
# - Set REDIS_ENABLED=true and point to managed Redis service

