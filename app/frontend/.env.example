# New Era Recovery - Frontend Environment Variables
# Copy this file to .env.development.local, .env.production.local, etc.

# ============================================
# API Configuration
# ============================================

# Backend API base URL
# Development: local backend
VITE_API_BASE=http://localhost:4000

# ============================================
# Application Settings
# ============================================

# Application environment (development, staging, production)
VITE_ENV=development

# Application name/title
VITE_APP_NAME=New Era Recovery

# ============================================
# Development Notes
# ============================================

# For local development:
# - Copy to .env.development.local
# - Use local backend URL (http://localhost:4000)
# - Leave other values as defaults
#
# For production builds:
# - Copy to .env.production.local
# - Use production backend URL
# - Use production application settings
#
# Vite environment variable naming:
# - Prefix with VITE_ to expose to browser
# - Variables without VITE_ are private (build-only)
